# Alpaca paper trading (https://app.alpaca.markets -> Paper Trading -> API Keys)
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=

# Use paper endpoints (default true)
ALPACA_PAPER=true

# Optional overrides (defaults match Alpaca docs)
# ALPACA_TRADING_BASE_URL=https://paper-api.alpaca.markets
# ALPACA_DATA_REST_URL=https://data.alpaca.markets
# ALPACA_DATA_WS_URL=wss://stream.data.alpaca.markets/v2/iex

# Hydra (when a hydra-node is reachable)
HYDRA_HOST=127.0.0.1
HYDRA_PORT=4001
HYDRA_SECURE=false
HYDRA_HISTORY=yes
